# byteful-sdk environment variables.
#
# Copy this file to ``.env`` and fill in your values. ``tests/conftest.py``
# loads ``.env`` automatically via python-dotenv, so anything set here is
# visible to pytest without further setup.
#
# Required vars gate the integration suite (``pytest -m integration``);
# optional vars unlock additional targeted tests when present.

# ---- REQUIRED: API credentials -------------------------------------------
#
# Generate at https://dashboard.byteful.com/developer/api-key
#
# Without both of these set, ``pytest -m integration`` skips every
# integration test (unit tests are unaffected).

BYTEFUL_API_PUBLIC_KEY=pub_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BYTEFUL_API_PRIVATE_KEY=priv_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ---- OPTIONAL: known-resource fixtures -----------------------------------
#
# These let integration tests target specific resources you already own,
# rather than guessing from search results. Each is independently optional:
# tests that need an unset value are skipped, not failed.

# A specific proxy UUID on your account. Used for ``proxy_retrieve(id)``
# and ``proxy_list_by_id`` round-trip tests.
# BYTEFUL_TEST_PROXY_ID=7a018d34-76c2-4c23-b14d-f7b9a7054e25

# A specific service ID. Used for ``service_retrieve(id)``,
# ``service_adjustment_search(service_id=...)`` and friends.
# BYTEFUL_TEST_SERVICE_ID=API-1234-5678

# A specific proxy_user ID. Used for ``proxy_user_retrieve(id)`` and to
# scope ``proxy_user_acl_search`` / generated-list tests.
# BYTEFUL_TEST_PROXY_USER_ID=stevejobs

# Default country to use for geographic searches and availability queries
# (e.g. ``proxy_search(country_id=...)``). Falls back to "us" when unset.
# BYTEFUL_TEST_COUNTRY_ID=us

# Default proxy_type to use for filter tests. One of:
#   datacenter | isp | residential | mobile
# Use whichever product family you actually have provisioned. Falls back to
# "isp" when unset.
# BYTEFUL_TEST_PROXY_TYPE=isp


# ---- OPTIONAL: opt-in mutation tests -------------------------------------
#
# By default the integration suite is strictly read-only — safe to run
# against production. Set the flag below to enable create+cleanup
# round-trip tests on free, easily-reversible resources (proxy_users and
# proxy_user_acls). The tests delete what they create on teardown, but if
# pytest is killed mid-run you may need to clean up by hand.
#
# Checkout (``checkout_create``) and service-mutation tests are *never*
# auto-enabled — they cost real money — and have no opt-in flag in this
# file by design.

# BYTEFUL_TEST_ALLOW_MUTATIONS=1


# ---- OPTIONAL: opt out of the live leak-check probe ----------------------
#
# By default the integration suite samples up to 5 random ``in_use``
# proxies and routes a "what's my IP" check through each one to confirm
# the destination sees the byteful-declared egress (and not your real
# IP). The probe is read-only from byteful's perspective and uses a
# tiny amount of proxy bandwidth.
#
# Set the flag below to skip the probe — useful for offline CI runs or
# fast-feedback iterations.

# BYTEFUL_TEST_SKIP_LEAK_CHECK=1
